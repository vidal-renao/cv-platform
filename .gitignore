# ─── Dependencies ─────────────────────────────────────────
node_modules/

# ─── Build output ─────────────────────────────────────────
.next/
out/
dist/

# ─── Environment variables (real secrets — never commit) ──
# Root-level
.env
.env.local
.env.*.local

# Backend
backend/.env
backend/.env.local
backend/.env.*.local

# Frontend
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ── .env.example and .env.local.example are safe to commit ─
# (they contain no secrets, only documentation)
# Git tracks them unless they match a pattern above — they don't.

# ─── Logs ─────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ─── OS & editor ──────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
