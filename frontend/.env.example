# Frontend / Next.js runtime

NODE_ENV=development
APP_ENV=local

# Public canonical URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Database for Next API routes
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE_TEST

# Auth
# Must be at least 32 random characters in staging/production.
JWT_SECRET=replace_with_32_plus_random_characters

# Cookie policy
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# Edge API rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=10
RATE_LIMIT_MAX_CHAT=60
RATE_LIMIT_MAX_UPLOAD=20
RATE_LIMIT_MAX_API=100

# Email / WhatsApp
RESEND_API_KEY=re_replace_with_real_key_in_runtime
RESEND_FROM_EMAIL=noreply@example.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_in_runtime_only
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
