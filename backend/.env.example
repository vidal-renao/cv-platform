# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── Database ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/cv_platform

# ─── Auth ─────────────────────────────────────────────────
# Must be at least 32 random characters in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_32_char_secret

# ─── Email — Resend ───────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# Must be a domain verified in your Resend account
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── WhatsApp — Twilio ────────────────────────────────────
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Sandbox number (dev): whatsapp:+14155238886
# Production: whatsapp:+your_approved_number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Client Access ────────────────────────────────────────
# Temporary password sent to clients when generating portal access
DEFAULT_TEMP_PASSWORD=change_me_to_a_secure_temp_password

# ─── Environment ──────────────────────────────────────────
# Set to "production" to suppress verbose error logs
NODE_ENV=development
