# ─── Server ───────────────────────────────────────────────
PORT=5000
APP_ENV=local

# ─── Database ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/cv_platform
TEST_DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/cv_platform_test

# ─── Auth ─────────────────────────────────────────────────
# Must be at least 32 random characters in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_32_char_secret

# ─── Email — Resend ───────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# Must be a domain verified in your Resend account
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── WhatsApp — Twilio ────────────────────────────────────
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Sandbox number (dev): whatsapp:+14155238886
# Production: whatsapp:+your_approved_number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Client Access ────────────────────────────────────────
# Client access uses one-time setup/reset links. Do not send temporary passwords.
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=10
RATE_LIMIT_MAX_CHAT=60
RATE_LIMIT_MAX_UPLOAD=20
RATE_LIMIT_MAX_API=100

# ─── Environment ──────────────────────────────────────────
# Set to "production" to suppress verbose error logs
NODE_ENV=development
