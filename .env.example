# Root reference only. Configure frontend/backend env vars in each runtime.

# Environments
NODE_ENV=development
APP_ENV=local

# Public app URLs
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE_TEST

# Auth
# Must be at least 32 random characters. Do not reuse between environments.
JWT_SECRET=replace_with_32_plus_random_characters

# Cookies / CORS
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=10
RATE_LIMIT_MAX_CHAT=60
RATE_LIMIT_MAX_UPLOAD=20
RATE_LIMIT_MAX_API=100
